# inkbridge device connection — copy this file to .env and fill in your values.
# .env is gitignored and must never be committed.

# rMPP USB-network address (the standard reMarkable USB RNDIS IP — rarely needs changing).
INKBRIDGE_HOST=10.11.99.1

# SSH user on the device (root on reMarkable Paper Pro).
INKBRIDGE_USER=root

# Device root SSH password — UNIQUE PER DEVICE.
# Find it on the tablet: Settings > Help > Copyrights and licenses (scroll to the bottom).
INKBRIDGE_PW=
